@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Đổi mật khẩu</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background: #2C4963;
        }

        .box {
            max-width: 400px;
            margin: auto;
            margin-top: 100px;
            background: white;
            padding: 30px;
            border-radius: 15px;
        }
    </style>
</head>
<body>

    <div class="box shadow">

        <h4 class="text-center mb-4">Đổi mật khẩu</h4>

        <!-- 🔥 DÁN FORM VÀO ĐÂY -->
        <form method="post" action="/Login/ResetPassword">

            <div class="mb-3">
                <label>UserName</label>
                <input name="username" class="form-control" placeholder="email@example.com" />
            </div>

            <div class="mb-3">
                <label>Mật khẩu cũ</label>
                <input type="password" name="oldPassword" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Mật khẩu mới</label>
                <input type="password" name="newPassword" class="form-control" />
            </div>

            <div class="mb-3">
                <label>Mã xác nhận</label>
                <input name="verificationCode" class="form-control" placeholder="123456" />
            </div>

            <button class="btn btn-dark w-100">Đổi mật khẩu</button>

            <div class="text-center mt-3">
                <a href="/Login/LoginIndex">Quay lại đăng nhập</a>
            </div>

        </form>

        <!-- Hiển thị lỗi -->
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger mt-3">
                @ViewBag.Error
            </div>
        }

        <!-- Hiển thị thành công -->
        @if (ViewBag.Success != null)
        {
            <div class="alert alert-success mt-3">
                @ViewBag.Success
            </div>
        }

    </div>

</body>
</html>