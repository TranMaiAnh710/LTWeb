@model System.Collections.Generic.List<BTL.Models.ChamCong>
@{ ViewBag.Title = "Lịch sử chấm công"; }
<h2 style="margin-top:0">Lịch sử chấm công của tôi</h2>
<table style="width:100%;background:#fff;border-collapse:collapse;margin-top:16px;border-radius:8px;overflow:hidden">
    <thead style="background:#f1f5f9"><tr><th style="padding:12px;text-align:left">Ngày</th><th style="padding:12px;text-align:center">Giờ vào</th><th style="padding:12px;text-align:center">Giờ ra</th><th style="padding:12px;text-align:center">Giờ làm</th><th style="padding:12px;text-align:center">Đi muộn</th><th style="padding:12px;text-align:center">Về sớm</th><th style="padding:12px;text-align:center">Tăng ca</th><th style="padding:12px;text-align:center">Trạng thái</th></tr></thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr style="border-top:1px solid #e5e7eb">
                <td style="padding:10px 12px"><strong>@c.Ngay.ToString("dd/MM/yyyy")</strong></td>
                <td style="padding:10px 12px;text-align:center">@c.ThoiGianVao.ToString("HH:mm")</td>
                <td style="padding:10px 12px;text-align:center">@c.ThoiGianRa.ToString("HH:mm")</td>
                <td style="padding:10px 12px;text-align:center">@(c.SoGioLam.HasValue ? c.SoGioLam.Value.ToString(@"hh\:mm") : "-")</td>
                <td style="padding:10px 12px;text-align:center">@(c.GioDiMuon.HasValue ? c.GioDiMuon.Value.ToString(@"hh\:mm") : "-")</td>
                <td style="padding:10px 12px;text-align:center">@(c.GioVeSom.HasValue ? c.GioVeSom.Value.ToString(@"hh\:mm") : "-")</td>
                <td style="padding:10px 12px;text-align:center">@(c.GioTangCa.HasValue ? c.GioTangCa.Value.ToString(@"hh\:mm") : "-")</td>
                <td style="padding:10px 12px;text-align:center">@c.TrangThai</td>
            </tr>
        }
        @if (Model.Count == 0) { <tr><td colspan="8" style="padding:20px;text-align:center;color:#94a3b8">Chưa có dữ liệu chấm công</td></tr> }
    </tbody>
</table>
