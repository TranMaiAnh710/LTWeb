@model System.Collections.Generic.List<BTL.Models.HopDong>
@{ ViewBag.Title = "Hợp đồng của tôi"; }
<h2 style="margin-top:0">Hợp đồng lao động của tôi</h2>
@if (Model.Count == 0)
{
    <p style="color:#64748b">Chưa có hợp đồng nào.</p>
}
else
{
    foreach (var hd in Model)
    {
        <div style="background:#fff;padding:24px;border-radius:8px;margin-bottom:14px;border-left:4px solid #2563eb">
            <div style="display:flex;justify-content:space-between;align-items:center">
                <h3 style="margin:0">@hd.SoHopDong</h3>
                <span style="padding:4px 12px;background:@(hd.TrangThai == "HieuLuc" ? "#dcfce7" : "#fee2e2");color:@(hd.TrangThai == "HieuLuc" ? "#166534" : "#991b1b");border-radius:12px;font-size:13px">@hd.TrangThai</span>
            </div>
            <p><strong>Loại:</strong> @hd.LoaiHopDong</p>
            <p><strong>Thời hạn:</strong> @hd.NgayBatDau.ToString("dd/MM/yyyy") — @(hd.NgayKetThuc.HasValue ? hd.NgayKetThuc.Value.ToString("dd/MM/yyyy") : "Vô thời hạn")</p>
            <p><strong>Lương HĐ:</strong> @hd.LuongHopDong.ToString("N0") VND</p>
            <p><strong>Người ký:</strong> @hd.NguoiKy — Ngày ký: @hd.NgayKy.ToString("dd/MM/yyyy")</p>
            @if (!string.IsNullOrEmpty(hd.NoiDung)) { <details><summary style="cursor:pointer;color:#2563eb">Xem nội dung</summary><div style="padding:12px;background:#f8fafc;border-radius:6px;margin-top:8px;white-space:pre-wrap">@hd.NoiDung</div></details> }
        </div>
    }
}
