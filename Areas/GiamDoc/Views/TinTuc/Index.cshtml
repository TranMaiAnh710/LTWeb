@model System.Collections.Generic.List<BTL.Models.TinTuc>
@{ ViewBag.Title = "Quản lý tin tức"; }
<div style="display:flex;justify-content:space-between;align-items:center">
    <h2 style="margin:0">Đăng bài / Quản lý tin tức</h2>
    <a href="@Url.Action("Create")" style="padding:8px 16px;background:#2563eb;color:#fff;text-decoration:none;border-radius:6px">+ Đăng bài mới</a>
</div>
<p style="color:#64748b;margin-top:8px">Các bài đăng ở đây sẽ hiển thị trên trang chủ công khai.</p>
<table style="width:100%;background:#fff;border-collapse:collapse;margin-top:16px;border-radius:8px;overflow:hidden">
    <thead style="background:#f1f5f9">
        <tr>
            <th style="padding:12px;text-align:left">Tiêu đề</th>
            <th style="padding:12px;text-align:center">Loại</th>
            <th style="padding:12px;text-align:center">Tác giả</th>
            <th style="padding:12px;text-align:center">Ngày đăng</th>
            <th style="padding:12px;text-align:center">Nổi bật</th>
            <th style="padding:12px;text-align:right">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            var color = t.LoaiTin == "SuKien" ? "#f59e0b" : t.LoaiTin == "ThongBao" ? "#16a34a" : "#2563eb";
            var label = t.LoaiTin == "SuKien" ? "Sự kiện" : t.LoaiTin == "ThongBao" ? "Thông báo" : "Tin tức";
            <tr style="border-top:1px solid #e5e7eb">
                <td style="padding:10px 12px"><strong>@t.TieuDe</strong><br /><small style="color:#94a3b8">@t.TomTat</small></td>
                <td style="padding:10px 12px;text-align:center"><span style="padding:3px 10px;background:@color;color:#fff;border-radius:12px;font-size:12px">@label</span></td>
                <td style="padding:10px 12px;text-align:center">@t.TacGia</td>
                <td style="padding:10px 12px;text-align:center">@t.NgayDang.ToString("dd/MM/yyyy")</td>
                <td style="padding:10px 12px;text-align:center">@(t.NoiBat ? "⭐" : "")</td>
                <td style="padding:10px 12px;text-align:right">
                    <a href="/Home/ChiTiet/@t.MaTin" target="_blank" style="color:#64748b;margin-right:12px">Xem</a>
                    <a href="@Url.Action("Edit",new{id=t.MaTin})" style="color:#2563eb;margin-right:12px">Sửa</a>
                    <a href="@Url.Action("Delete",new{id=t.MaTin})" onclick="return confirm('Xóa bài này?')" style="color:#dc2626">Xóa</a>
                </td>
            </tr>
        }
        @if (Model.Count == 0)
        {
            <tr><td colspan="6" style="padding:20px;text-align:center;color:#94a3b8">Chưa có bài đăng nào</td></tr>
        }
    </tbody>
</table>
