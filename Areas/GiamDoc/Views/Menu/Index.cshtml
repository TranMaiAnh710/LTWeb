@model System.Collections.Generic.List<BTL.Models.Menu>
@{ ViewBag.Title = "Quản lý Menu"; }
<div style="display:flex;justify-content:space-between;align-items:center">
    <h2 style="margin:0">Quản lý Menu hệ thống</h2>
    <a href="@Url.Action("Create")" style="padding:8px 16px;background:#2563eb;color:#fff;text-decoration:none;border-radius:6px">+ Thêm Menu</a>
</div>
<p style="color:#64748b;margin-top:8px">Danh sách các mục menu hiển thị trong sidebar. Gán cho role qua bảng Role_Menu.</p>
<table style="width:100%;background:#fff;border-collapse:collapse;margin-top:16px;border-radius:8px;overflow:hidden">
    <thead style="background:#f1f5f9">
        <tr>
            <th style="padding:12px;text-align:left">ID</th>
            <th style="padding:12px;text-align:left">Tên menu</th>
            <th style="padding:12px;text-align:left">Đường dẫn</th>
            <th style="padding:12px;text-align:center">Thứ tự</th>
            <th style="padding:12px;text-align:right">Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in Model)
        {
            <tr style="border-top:1px solid #e5e7eb">
                <td style="padding:10px 12px">@m.MenuID</td>
                <td style="padding:10px 12px"><strong>@m.MenuName</strong></td>
                <td style="padding:10px 12px"><code style="background:#f1f5f9;padding:2px 6px;border-radius:4px;font-size:12px">@m.MenuLink</code></td>
                <td style="padding:10px 12px;text-align:center">@m.MenuOrder</td>
                <td style="padding:10px 12px;text-align:right">
                    <a href="@Url.Action("Edit",new{id=m.MenuID})" style="color:#2563eb;margin-right:12px">Sửa</a>
                    <a href="@Url.Action("Delete",new{id=m.MenuID})" onclick="return confirm('Xóa menu này? (xóa cả role_menu liên quan)')" style="color:#dc2626">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
