@model IEnumerable<BTL.Models.NhanVien>
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Thông tin nhân sự</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f3f4f6;
            font-family: "Segoe UI", sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: #0f172a;
            color: #cbd5f5;
            height: 100vh;
            padding: 20px 16px;
            position: relative;
        }

        .logo {
            font-weight: 600;
            color: white;
            margin-bottom: 20px;
        }

        .menu-title {
            font-size: 11px;
            margin-top: 20px;
            color: #64748b;
        }

        .menu-item {
            padding: 10px 12px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

            .menu-item:hover {
                background: #1e293b;
            }

            .menu-item.active {
                background: #2563eb;
                color: white;
            }

        /* MAIN */
        .main {
            flex-grow: 1;
        }

        .header {
            background: white;
            padding: 14px 20px;
            border-bottom: 1px solid #e5e7eb;
        }

        .content {
            padding: 20px;
        }

        /* CARD */
        .card-box {
            background: white;
            border-radius: 12px;
            border: 1px solid #e5e7eb;
            padding: 20px;
        }

        /* SEARCH */
        .search-box {
            display: flex;
            align-items: center;
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 6px 10px;
        }

            .search-box input {
                border: none;
                outline: none;
                margin-left: 5px;
            }

        /* TABLE */
        .table tbody tr:hover {
            background: #f9fafb;
        }

        .salary {
            color: #16a34a;
            font-weight: 500;
        }

        /* USER */
        .sidebar-user {
            position: absolute;
            bottom: 20px;
            left: 16px;
            right: 16px;
        }
    </style>
</head>

<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="logo">🏢 CompanyOS</div>

            <div class="menu-title">TỔNG QUAN</div>
            <a href="@Url.Action("Index","Dashboard", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">📊 Dashboard</a>

            <div class="menu-title">QUẢN LÝ</div>
            <a href="@Url.Action("Index","Account", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">👤 Tài khoản </a>
            <a href="@Url.Action("Index","ChamCong", new { area = "NhanSu" })" class="menu-item text-decoration-none text-light">⏱ Chấm công</a>
            <div class="menu-item active">📄 Nhân sự</div>

            <div class="menu-title">TÀI CHÍNH</div>
            <a href="@Url.Action("Index","Payroll", new { area = "KeToan" })" class="menu-item text-decoration-none text-light">💰 Bảng lương</a>
            <a href="@Url.Action("Index","PayrollDetail", new { area = "KeToan" })" class="menu-item text-decoration-none text-light">📘 Nhật ký</a>

            <div class="menu-title">HỆ THỐNG</div>
            <a href="@Url.Action("Index","Menu", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">⚙ Cấu hình</a>
            <div class="sidebar-user">
                <div class="d-flex align-items-center gap-2">

                    <!-- Avatar -->
                    <div class="avatar bg-blue">
                        @(ViewBag.HotenNV != null ? ViewBag.HotenNV.Substring(0,1) : "")
                    </div>

                    <!-- Info -->
                    <div>
                        <div class="text-white fw-semibold">@ViewBag.HotenNV</div>
                        <small class="text-secondary">@ViewBag.TenCV</small>
                    </div>
                </div>

                <!-- Logout -->
                <a href="@Url.Action("Logout","Account")"
                   class="d-block mt-2 text-decoration-none text-light">
                    ← Đăng xuất
                </a>
            </div>
        </div>
        <!-- MAIN -->
        <div class="main">

            <!-- HEADER -->
            <div class="header">
                <b>Danh sách nhân sự</b>
            </div>

            <!-- CONTENT -->
            <div class="content">

                <div class="card-box">

                    <!-- HEADER CARD -->
                    <div class="d-flex gap-2 mb-3 flex-wrap">

                        <!-- SEARCH -->
                        <input type="text" id="searchInput" class="form-control w-auto"
                               placeholder="🔍 Tìm HotenNV..." />

                        <!-- PHÒNG BAN -->
                        <select class="form-select w-auto">
                            <option>Tất cả MaPB</option>
                            @foreach (var pb in ViewBag.PhongBans as List<BTL.Models.PhongBan>)
                            {
                                <option value="@pb.MaPB">@pb.TenPB</option>
                            }
                        </select>

                        <!-- CHỨC VỤ -->
                        <select class="form-select w-auto">
                            <option>Tất cả MaCV</option>
                            @foreach (var cv in ViewBag.ChucVus as List<BTL.Models.ChucVu>)
                            {
                                <option value="@cv.MaCV">@cv.TenCV</option>
                            }
                        </select>

                        <!-- TRẠNG THÁI -->
                        <select class="form-select w-auto">
                            <option>Trạng thái: Tất cả</option>
                            <option>Đang làm</option>
                            <option>Nghỉ</option>
                        </select>

                        <!-- BUTTON -->
                        <a href="@Url.Action("Create")" class="btn btn-dark">
                            + Thêm Nhân Viên
                        </a>

                    </div>

                    <!-- TABLE -->
                    <table class="table">
                        <thead>
                            <tr class="border-bottom">
                                <th>Mã NV</th>
                                <th>Họ tên</th>
                                <th>Phòng ban</th>
                                <th>Chức vụ</th>
                                <th>Lương</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody id="employeeTable">
                            @foreach (var emp in Model)
                            {
                                <tr>
                                    <td>@emp.MaNV</td>
                                    <td>@emp.HotenNV</td>
                                    <td>@(emp.PhongBan?.TenPB ?? "--")</td>
                                    <td>@(emp.ChucVu?.TenCV ?? "--")</td>
                                    <td class="salary">@emp.LuongCBan.ToString("N0")</td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-link text-primary p-0"
                                                onclick="showDetail(@emp.MaNV)">
                                            Chi tiết
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>

            </div>
        </div>

    </div>

    <!-- SEARCH -->
    <script>
        const searchInput = document.getElementById("searchInput");
        const rows = document.querySelectorAll("#employeeTable tr");

        searchInput.addEventListener("keyup", function () {
            const keyword = this.value.toLowerCase();

            rows.forEach(row => {
                const text = row.innerText.toLowerCase();
                row.style.display = text.includes(keyword) ? "" : "none";
            });
        });
    </script>
    <script>
    function showDetail(id) {
        fetch('@Url.Action("DetailsPartial","Employee", new { area = "NhanSu" })?id=' + id)
            .then(res => res.text())
            .then(html => {
                document.getElementById("modalContent").innerHTML = html;

                const modal = new bootstrap.Modal(document.getElementById('employeeModal'));
                modal.show();
            })
            .catch(err => console.error(err));
    }
    </script>
    <div class="modal fade" id="employeeModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" id="modalContent">
                <div class="p-4 text-center">Đang tải...</div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
