@model System.Collections.Generic.List<BTL.Models.HopDong>
@{
    ViewBag.Title = "Quản lý hợp đồng";
    var nvs = ViewBag.NhanViens as System.Collections.Generic.Dictionary<int, string>;
}
<div style="display:flex;justify-content:space-between;align-items:center">
    <h2 style="margin:0">Quản lý hợp đồng</h2>
    <a href="@Url.Action("Create")" style="padding:8px 16px;background:#2563eb;color:#fff;text-decoration:none;border-radius:6px">+ Thêm hợp đồng</a>
</div>
<table style="width:100%;background:#fff;border-collapse:collapse;margin-top:16px;border-radius:8px;overflow:hidden;font-size:14px">
    <thead style="background:#f1f5f9"><tr><th style="padding:12px;text-align:left">Số HĐ</th><th style="padding:12px;text-align:left">Nhân viên</th><th style="padding:12px;text-align:left">Loại</th><th style="padding:12px">Bắt đầu</th><th style="padding:12px">Kết thúc</th><th style="padding:12px;text-align:right">Lương</th><th style="padding:12px;text-align:center">Trạng thái</th><th style="padding:12px;text-align:right">Thao tác</th></tr></thead>
    <tbody>
        @foreach (var hd in Model)
        {
            var tenNV = nvs != null && nvs.ContainsKey(hd.MaNV) ? nvs[hd.MaNV] : "(?)";
            <tr style="border-top:1px solid #e5e7eb">
                <td style="padding:10px 12px"><strong>@hd.SoHopDong</strong></td>
                <td style="padding:10px 12px">@tenNV</td>
                <td style="padding:10px 12px">@hd.LoaiHopDong</td>
                <td style="padding:10px 12px">@hd.NgayBatDau.ToString("dd/MM/yy")</td>
                <td style="padding:10px 12px">@(hd.NgayKetThuc.HasValue ? hd.NgayKetThuc.Value.ToString("dd/MM/yy") : "-")</td>
                <td style="padding:10px 12px;text-align:right">@hd.LuongHopDong.ToString("N0")</td>
                <td style="padding:10px 12px;text-align:center">@hd.TrangThai</td>
                <td style="padding:10px 12px;text-align:right"><a href="@Url.Action("Edit",new{id=hd.MaHD})" style="color:#2563eb">Sửa</a></td>
            </tr>
        }
    </tbody>
</table>
