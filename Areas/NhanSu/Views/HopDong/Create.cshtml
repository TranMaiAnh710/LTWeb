@model BTL.Models.HopDong
@{ ViewBag.Title = "Thêm hợp đồng"; }
<h2 style="margin-top:0">Thêm hợp đồng lao động</h2>
<div style="background:#fff;padding:24px;border-radius:8px;max-width:700px">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Số hợp đồng</label>@Html.TextBoxFor(m => m.SoHopDong, new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Nhân viên</label>@Html.DropDownListFor(m => m.MaNV, ViewBag.NhanViens as SelectList, "-- Chọn --", new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Loại hợp đồng</label>@Html.DropDownListFor(m => m.LoaiHopDong, new SelectList(new[] { "Thu viec", "Xac dinh thoi han", "Khong xac dinh thoi han" }), new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Trạng thái</label>@Html.DropDownListFor(m => m.TrangThai, new SelectList(new[] { "HieuLuc", "HetHan", "TamNgung", "DaHuy" }), new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Ngày bắt đầu</label>@Html.TextBoxFor(m => m.NgayBatDau, "{0:yyyy-MM-dd}", new { type = "date", style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Ngày kết thúc</label>@Html.TextBoxFor(m => m.NgayKetThuc, "{0:yyyy-MM-dd}", new { type = "date", style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Lương HĐ</label>@Html.TextBoxFor(m => m.LuongHopDong, new { type = "number", step = "0.01", style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div><label style="display:block;font-weight:600;margin-bottom:6px">Ngày ký</label>@Html.TextBoxFor(m => m.NgayKy, "{0:yyyy-MM-dd}", new { type = "date", style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div style="grid-column:span 2"><label style="display:block;font-weight:600;margin-bottom:6px">Người ký</label>@Html.TextBoxFor(m => m.NguoiKy, new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })</div>
            <div style="grid-column:span 2"><label style="display:block;font-weight:600;margin-bottom:6px">Nội dung</label>@Html.TextAreaFor(m => m.NoiDung, new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px;min-height:80px" })</div>
        </div>
        <div style="margin-top:20px"><button type="submit" style="padding:10px 24px;background:#2563eb;color:#fff;border:none;border-radius:6px">Lưu hợp đồng</button> <a href="@Url.Action("Index")" style="margin-left:8px">Hủy</a></div>
    }
</div>
