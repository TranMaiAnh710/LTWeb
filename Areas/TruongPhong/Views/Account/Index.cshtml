@model List<BTL.Models.Account>
@{
    var roles = ViewBag.Roles as List<BTL.Models.Role> ?? new List<BTL.Models.Role>();
    var employees = ViewBag.Employees as List<BTL.Models.NhanVien>
                    ?? new List<BTL.Models.NhanVien>();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Account</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            margin: 0;
            background: #f3f4f6;
            font-family: "Segoe UI", sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: #0f172a;
            color: #cbd5f5;
            height: 100vh;
            position: relative; /* 🔥 THÊM */
            padding: 20px 16px;
        }

        <style >
        body {
            margin: 0;
            background: #f3f4f6;
            font-family: "Segoe UI", sans-serif;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            background: #0f172a;
            color: #cbd5f5;
            height: 100vh;
            position: relative; /* 🔥 THÊM */
            padding: 20px 16px;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            color: white;
            margin-bottom: 20px;
        }

        .menu-title {
            font-size: 11px;
            text-transform: uppercase;
            margin-top: 20px;
            margin-bottom: 8px;
            color: #64748b;
        }

        .menu-item {
            padding: 10px 12px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
        }

            .menu-item:hover {
                background: #1e293b;
            }

            .menu-item.active {
                background: #2563eb;
                color: white;
            }

        /* HEADER */
        .header {
            background: white;
            padding: 14px 20px;
            border-bottom: 1px solid #e5e7eb;
        }

        .badge-soft {
            background: #dbeafe;
            color: #2563eb;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        /* CARD */
        .card-box {
            background: white;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            padding: 20px;
        }

        .stat-card {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .i-gray {
            background: #374151;
        }

        .i-green {
            background: #22c55e;
        }

        .i-green2 {
            background: #16a34a;
        }

        .i-yellow {
            background: #f59e0b;
        }

        /* PROGRESS */
        .progress {
            height: 8px;
            border-radius: 10px;
            background: #e5e7eb;
        }

        .progress-bar {
            background: #22c55e;
        }

        .row-line {
            display: flex;
            justify-content: space-between;
            font-size: 13px;
        }

        /* EMPLOYEE */
        .emp {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }

            .emp:last-child {
                border-bottom: none;
            }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
        }

        .bg-red {
            background: #ef4444;
        }

        .bg-green {
            background: #22c55e;
        }

        .bg-blue {
            background: #3b82f6;
        }

        .status-pill {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .s-red {
            background: #fee2e2;
            color: #b91c1c;
        }

        .s-green {
            background: #dcfce7;
            color: #166534;
        }

        .s-blue {
            background: #dbeafe;
            color: #1d4ed8;
        }

        /* TABLE */
        .table thead {
            background: #f9fafb;
        }

        .pill {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
        }

        .paid {
            background: #dcfce7;
            color: #166534;
        }

        .pending {
            background: #fef3c7;
            color: #92400e;
        }

        .sidebar-user {
            position: absolute;
            bottom: 20px;
            left: 16px;
            right: 16px;
            background: rgba(255,255,255,0.05);
            padding: 12px;
            border-radius: 10px;
        }
    </style>
</head>

<body>
    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="logo">🏢 CompanyOS</div>

            <div class="menu-title">TỔNG QUAN</div>
            <a href="@Url.Action("Index","Dashboard", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">📊 Dashboard</a>

            <div class="menu-title">QUẢN LÝ</div>
            <div class="menu-item active">👤 Tài khoản</div>
            <a href="@Url.Action("Index","ChamCong", new { area = "NhanSu" })" class="menu-item text-decoration-none text-light">⏱ Chấm công</a>
            <a href="@Url.Action("Index","Employee", new { area = "NhanSu" })" class="menu-item text-decoration-none text-light">📄 Nhân sự</a>

            <div class="menu-title">TÀI CHÍNH</div>
            <a href="@Url.Action("Index","Payroll", new { area = "KeToan" })" class="menu-item text-decoration-none text-light">💰 Bảng lương</a>
            <a href="@Url.Action("Index","PayrollDetail", new { area = "KeToan" })" class="menu-item text-decoration-none text-light">📘 Nhật ký</a>

            <div class="menu-title">HỆ THỐNG</div>
            <a href="@Url.Action("Index","Menu", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">⚙ Cấu hình</a>
            <div class="sidebar-user">
                <div class="d-flex align-items-center gap-2">

                    <!-- Avatar -->
                    <div class="avatar bg-blue">
                        @(ViewBag.HotenNV != null ? ViewBag.HotenNV.Substring(0,1) : "")
                    </div>

                    <!-- Info -->
                    <div>
                        <div class="text-white fw-semibold">@ViewBag.HotenNV</div>
                        <small class="text-secondary">@ViewBag.TenCV</small>
                    </div>
                </div>

                <!-- Logout -->
                <a href="@Url.Action("Logout","Account",new { area = "TruongPhong" })"
                   class="d-block mt-2 text-decoration-none text-light">
                    ← Đăng xuất
                </a>
            </div>
        </div>

        <!-- MAIN -->
        <div class="flex-grow-1">

            <div class="header">
                <b>Tài khoản người dùng</b>
            </div>

            <div class="p-4">
                <div class="card-box">

                    <!-- FILTER -->
                    <form method="get" class="d-flex gap-2 mb-3">
                        <input name="search" value="@Request["search"]" class="form-control w-25" placeholder="UserName / Họ tên..." />

                        <select name="roleId" class="form-select w-auto">
                            <option value="">Tất cả Role</option>
                            @foreach (var r in roles)
                            {
                                <option value="@r.RoleID">@r.RoleName</option>
                            }
                        </select>

                        <button class="btn btn-primary">Lọc</button>
                        <button class="btn btn-success"
                                data-bs-toggle="modal"
                                data-bs-target="#createAccountModal">
                            + Thêm tài khoản
                        </button>
                    </form>

                    <!-- TABLE -->
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Username</th>
                                <th>Nhân viên</th>
                                <th>Role</th>
                                <th>Phòng ban</th>
                                <th>Trạng thái</th>
                                <th>Ngày tạo</th>
                                <th></th>
                            </tr>
                        </thead>

                        <tbody>
                            @{
                                int i = 1;
                            }

                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>#@i</td>
                                    <td>@item.UserName</td>

                                    <!-- NHÂN VIÊN -->
                                    <td class="d-flex align-items-center gap-2">
                                        <div class="avatar">
                                            @(item.NhanVien != null && !string.IsNullOrEmpty(item.NhanVien.HotenNV)
                                    ? item.NhanVien.HotenNV.Substring(0,1)
                                    : "?")
                                        </div>
                                        @(item.NhanVien != null ? item.NhanVien.HotenNV : "N/A")
                                    </td>

                                    <!-- ROLE -->
                                    <td>
                                        <span class="pill pill-blue">
                                            @(item.Role != null ? item.Role.RoleName : "")
                                        </span>
                                    </td>

                                    <!-- PHÒNG BAN -->
                                    <td>
                                        @(item.NhanVien != null && item.NhanVien.PhongBan != null
                                ? item.NhanVien.PhongBan.TenPB
                                : "--")
                                    </td>

                                    <!-- TRẠNG THÁI -->
                                    <td class="status-cell">
                                        @if (item.IsDeleted == false)
                                        {
                                            <span class="pill pill-green">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="pill pill-red">Khóa</span>
                                        }
                                    </td>

                                    <!-- NGÀY -->
                                    <td>
                                        @(item.CreatedAt.HasValue
                                ? item.CreatedAt.Value.ToString("yyyy-MM-dd")
                                : "")
                                    </td>

                                    <!-- BUTTON -->
                                    <td>
                                        @if (item.IsDeleted == false)
                                        {
                                            <button class="btn btn-sm btn-danger btn-lock" data-id="@item.UserID">
                                                Khóa
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-success btn-unlock" data-id="@item.UserID">
                                                Mở
                                            </button>
                                        }
                                    </td>
                                </tr>
                                i++;
                            }

                        </tbody>
                    </table>

                </div>
            </div>

        </div>
    </div>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).on("click", ".btn-lock", function () {
            var btn = $(this);
            var id = btn.data("id");

            if (!confirm("Khóa tài khoản này?")) return;

            $.post("/TruongPhong/Account/Lock", { id: id }, function (res) {
                if (res.success) {
                    // đổi trạng thái
                    btn.closest("tr").find(".status-cell")
                        .html('<span class="pill pill-red">Khóa</span>');

                    // đổi button
                    btn.removeClass("btn-danger btn-lock")
                        .addClass("btn-success btn-unlock")
                        .text("Mở");
                }
            });
        });

        $(document).on("click", ".btn-unlock", function () {
            var btn = $(this);
            var id = btn.data("id");

            if (!confirm("Mở tài khoản này?")) return;

            $.post("/TruongPhong/Account/Unlock", { id: id }, function (res) {
                if (res.success) {
                    // đổi trạng thái
                    btn.closest("tr").find(".status-cell")
                        .html('<span class="pill pill-green">Hoạt động</span>');

                    // đổi button
                    btn.removeClass("btn-success btn-unlock")
                        .addClass("btn-danger btn-lock")
                        .text("Khóa");
                }
            });
        });
    </script>
    <div class="modal fade" id="createAccountModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 rounded-4">

                <!-- HEADER -->
                <div class="modal-header bg-dark text-white">
                    <h5 class="modal-title fw-bold">
                        Thêm tài khoản
                    </h5>

                    <button type="button"
                            class="btn-close btn-close-white"
                            data-bs-dismiss="modal">
                    </button>
                </div>

                <!-- FORM -->
                <form method="post"
                      action="@Url.Action("CreateAccount","Account", new { area = "TruongPhong" })">

                    <div class="modal-body">

                        <!-- NHÂN VIÊN -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Nhân viên
                            </label>

                            <select name="MaNV"
                                    class="form-select"
                                    required>

                                <option value="">
                                    -- Chọn nhân viên --
                                </option>

                                @foreach (var nv in employees)
                                {
                                    <option value="@nv.MaNV">
                                        @nv.MaNV - @nv.HotenNV
                                    </option>
                                }
                            </select>
                        </div>

                        <!-- USERNAME -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Username
                            </label>

                            <input type="text"
                                   name="UserName"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Password
                            </label>

                            <input type="password"
                                   name="Password"
                                   class="form-control"
                                   required />
                        </div>

                        <!-- ROLE -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">
                                Chức vụ
                            </label>

                            <select name="RoleID"
                                    class="form-select"
                                    required>

                                <option value="">
                                    -- Chọn Role --
                                </option>

                                @foreach (var r in roles)
                                {
                                    <option value="@r.RoleID">
                                        @r.RoleName
                                    </option>
                                }
                            </select>
                        </div>

                    </div>

                    <!-- FOOTER -->
                    <div class="modal-footer">
                        <button type="button"
                                class="btn btn-secondary"
                                data-bs-dismiss="modal">
                            Đóng
                        </button>

                        <button type="submit"
                                class="btn btn-success">
                            + Thêm tài khoản
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>