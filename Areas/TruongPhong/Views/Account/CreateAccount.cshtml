@{
    var roles = ViewBag.Roles as List<BTL.Models.Role>;
}

<!-- Modal Thêm Tài Khoản -->
<div class="modal fade show d-block"
     tabindex="-1"
     style="background: rgba(0,0,0,0.5);">

    <div class="modal-dialog modal-dialog-centered"
         style="max-width: 700px;">

        <div class="modal-content border-0 rounded-4 overflow-hidden">

            <!-- Header -->
            <div class="modal-header border-0 px-4 py-3">

                <h4 class="fw-bold mb-0">
                    Thêm Tài Khoản
                </h4>

                <a href="@Url.Action("Index","Account", new { area = "TruongPhong" })"
                   class="btn-close">
                </a>

            </div>

            <!-- FORM -->
            <form method="post"
                  action="@Url.Action("Create","Account", new { area = "TruongPhong" })">

                <!-- Body -->
                <div class="modal-body p-0">

                    <!-- Banner -->
                    <div class="bg-dark text-white px-4 py-4"
                         style="background:#02133b !important;">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>

                                <h2 class="fw-bold mb-1">
                                    CÔNG TY ABC
                                </h2>

                                <div class="text-uppercase small opacity-75">
                                    Hệ thống quản lý tài khoản
                                </div>

                            </div>

                            <div class="text-end">

                                <div class="small opacity-75">
                                    Thêm mới
                                </div>

                                <div class="fs-2 fw-bold">
                                    ACCOUNT
                                </div>

                            </div>

                        </div>

                    </div>

                    <!-- Form -->
                    <div class="p-4">

                        <!-- MÃ NHÂN VIÊN -->
                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Mã nhân viên
                            </label>

                            <input type="number"
                                   name="MaNV"
                                   class="form-control form-control-lg"
                                   placeholder="Nhập mã nhân viên"
                                   required>

                        </div>

                        <!-- USERNAME -->
                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Tên tài khoản
                            </label>

                            <input type="text"
                                   name="UserName"
                                   class="form-control form-control-lg"
                                   placeholder="Nhập tên tài khoản"
                                   required>

                        </div>

                        <!-- PASSWORD -->
                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Mật khẩu
                            </label>

                            <input type="password"
                                   name="Password"
                                   class="form-control form-control-lg"
                                   placeholder="Nhập mật khẩu"
                                   required>

                        </div>

                        <!-- ROLE -->
                        <div class="mb-3">

                            <label class="form-label fw-semibold">
                                Chức vụ
                            </label>

                            <select name="RoleID"
                                    class="form-select form-select-lg"
                                    required>

                                <option value="">
                                    -- Chọn chức vụ --
                                </option>

                                @if (roles != null)
                                {
                                    foreach (var role in roles)
                                    {
                                        <option value="@role.RoleID">
                                            @role.RoleName
                                        </option>
                                    }
                                }

                            </select>

                        </div>

                    </div>

                </div>

                <!-- Footer -->
                <div class="modal-footer border-0 px-4 py-3">

                    <a href="@Url.Action("Index","Account", new { area = "TruongPhong" })"
                       class="btn btn-light px-4 border">

                        Đóng

                    </a>

                    <button type="submit"
                            class="btn btn-dark px-4">

                        + Thêm tài khoản

                    </button>

                </div>

            </form>

        </div>

    </div>

</div>