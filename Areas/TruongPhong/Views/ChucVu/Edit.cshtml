@model BTL.Models.ChucVu
@{ ViewBag.Title = "Sửa chức vụ"; }
<h2 style="margin-top:0">Sửa chức vụ</h2>
<div style="background:#fff;padding:24px;border-radius:8px;max-width:500px">
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.MaCV)
        <label style="display:block;font-weight:600;margin:8px 0 6px">Tên chức vụ</label>
        @Html.TextBoxFor(m => m.TenCV, new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px" })
        <label style="display:block;font-weight:600;margin:12px 0 6px">Phụ cấp chức vụ (VND)</label>
        @Html.TextBoxFor(m => m.PhuCapCV, new { style = "width:100%;padding:8px;border:1px solid #d1d5db;border-radius:6px", type = "number", step = "0.01" })
        <div style="margin-top:16px">
            <button type="submit" style="padding:8px 20px;background:#2563eb;color:#fff;border:none;border-radius:6px">Cập nhật</button>
            <a href="@Url.Action("Index")" style="margin-left:8px">Hủy</a>
        </div>
    }
</div>
