@{ ViewBag.Title = "Báo cáo chấm công"; }
<h2 style="margin-top:0">Báo cáo chấm công</h2>
<form method="get" style="margin:16px 0;background:#fff;padding:16px;border-radius:8px;border:1px solid #e5e7eb">
    Tháng: <input type="number" name="thang" value="@ViewBag.Thang" min="1" max="12" style="width:80px;padding:6px;border:1px solid #d1d5db;border-radius:6px" />
    Năm: <input type="number" name="nam" value="@ViewBag.Nam" min="2020" max="2030" style="width:110px;padding:6px;border:1px solid #d1d5db;border-radius:6px" />
    <button type="submit" style="padding:6px 14px;background:#2563eb;color:#fff;border:none;border-radius:6px">Xem</button>
</form>
<table style="width:100%;background:#fff;border-collapse:collapse;border-radius:8px;overflow:hidden">
    <thead style="background:#f1f5f9"><tr><th style="padding:12px;text-align:left">Nhân viên</th><th style="padding:12px;text-align:right">Số ngày công</th></tr></thead>
    <tbody>
        @foreach (dynamic r in ViewBag.Data) { <tr style="border-top:1px solid #e5e7eb"><td style="padding:10px 12px">@r.HoTen</td><td style="padding:10px 12px;text-align:right"><strong>@r.SoNgay</strong></td></tr> }
    </tbody>
</table>
