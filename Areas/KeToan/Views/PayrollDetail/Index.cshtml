@model IEnumerable<BTL.Models.NhatKyLuong>
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Nhật Ký Lương</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            background: #f3f4f6;
            font-family: "Segoe UI", sans-serif;
            overflow-x: hidden;
        }

        .wrapper {
            display: flex;
            width: 100%;
            min-height: 100vh;
        }

        /* SIDEBAR */
        .sidebar {
            width: 260px;
            min-width: 260px;
            background: #0f172a;
            color: #cbd5f5;
            min-height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            padding: 20px 16px;
            z-index: 1000;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 600;
            color: white;
            margin-bottom: 20px;
        }

        .menu-title {
            font-size: 11px;
            text-transform: uppercase;
            margin-top: 20px;
            margin-bottom: 8px;
            color: #64748b;
        }

        .menu-item {
            padding: 10px 12px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            transition: 0.2s;
        }

            .menu-item:hover {
                background: #1e293b;
            }

            .menu-item.active {
                background: #2563eb;
                color: white;
            }

        /* MAIN */
        .main {
            margin-left: 260px;
            width: calc(100% - 260px);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* HEADER */
        .header {
            background: white;
            padding: 18px 24px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* CONTENT */
        .content {
            padding: 24px;
            width: 100%;
        }

        /* CARD */
        .card-box {
            background: white;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            width: 100%;
            overflow: hidden;
        }

        .avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 12px;
            background: #3b82f6;
            font-weight: 600;
        }

        .table thead {
            background: #f9fafb;
        }

        .sidebar-user {
            position: absolute;
            bottom: 20px;
            left: 16px;
            right: 16px;
            background: rgba(255,255,255,0.05);
            padding: 12px;
            border-radius: 10px;
        }

        .search-box {
            display: flex;
            align-items: center;
            gap: 8px;
            background: white;
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 0 12px;
            height: 42px;
        }

            .search-box input {
                border: none;
                outline: none;
                width: 100%;
                background: transparent;
            }

        .table-responsive {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
        }
    </style>
</head>

<body>
    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar">
            <div class="logo">🏢 CompanyOS</div>

            <div class="menu-title">TỔNG QUAN</div>
            <a href="@Url.Action("Index","Dashboard", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">📊 Dashboard</a>

            <div class="menu-title">QUẢN LÝ</div>
            <a href="@Url.Action("Index","Account", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">👤 Tài khoản</a>
            <a href="@Url.Action("Index","ChamCong", new { area = "NhanSu" })" class="menu-item text-decoration-none text-light">⏱ Chấm công</a>
            <a href="@Url.Action("Index","Employee", new { area = "NhanSu" })" class="menu-item text-decoration-none text-light">📄 Nhân sự</a>

            <div class="menu-title">TÀI CHÍNH</div>
            <a href="@Url.Action("Index","Payroll", new { area = "KeToan" })" class="menu-item text-decoration-none text-light">💰 Bảng lương</a>
            <div class="menu-item active">📘 Nhật ký</div>

            <div class="menu-title">HỆ THỐNG</div>
            <a href="@Url.Action("Index","Menu", new { area = "TruongPhong" })" class="menu-item text-decoration-none text-light">⚙ Cấu hình</a>
            <div class="sidebar-user">
                <div class="d-flex align-items-center gap-2">

                    <!-- Avatar -->
                    <div class="avatar bg-blue">
                        @(ViewBag.HotenNV != null ? ViewBag.HotenNV.Substring(0,1) : "")
                    </div>

                    <!-- Info -->
                    <div>
                        <div class="text-white fw-semibold">@ViewBag.HotenNV</div>
                        <small class="text-secondary">@ViewBag.TenCV</small>
                    </div>
                </div>

                <!-- Logout -->
                <a href="@Url.Action("Logout","Account")"
                   class="d-block mt-2 text-decoration-none text-light">
                    ← Đăng xuất
                </a>
            </div>
        </div>
        <!-- MAIN -->
        <div class="main w-100">

            <!-- HEADER -->
            <div class="header">

                <div>
                    <h5 class="mb-1 fw-semibold text-dark">
                        Nhật ký lương
                    </h5>
                </div>

                <div class="d-flex align-items-center gap-3">

                    <span style="font-size:18px;">🔔</span>

                    <div class="px-3 py-2 bg-light rounded-pill small text-secondary">
                        📅 Th 2, 11/05/2026
                    </div>

                </div>

            </div>

            <!-- CONTENT -->
            <div class="content container-fluid">

                <!-- CARD -->
                <div class="card-box p-0 overflow-hidden">

                    <!-- TOP -->
                    <div class="px-4 py-3 border-bottom bg-light d-flex align-items-center gap-3">

                        <div class="fw-semibold">
                            Nhật ký lương
                        </div>

                    </div>

                    <!-- INFO -->
                    <div class="p-4">

                        <div class="alert alert-primary border-0 d-flex align-items-center mb-4"
                             style="background:#eef4ff; color:#1e40af;">

                            📑
                            <span class="ms-2">
                                Mỗi bản ghi NhatKyLuong lưu lịch sử thay đổi LuongCBan của NhanVien.
                                PhieuLuong tham chiếu qua IDNhatKy để tính lương đúng tại thời điểm áp dụng.
                            </span>

                        </div>

                        <!-- FILTER -->
                        <form method="get">

                            <div class="d-flex flex-wrap align-items-center gap-3 mb-4">

                                <!-- SEARCH -->
                                <div class="search-box" style="width:260px;">

                                    🔎

                                    <input type="text"
                                           name="search"
                                           value="@Request["search"]"
                                           placeholder="Tìm MaNV / Họ tên..." />

                                </div>

                                <!-- SELECT NHÂN VIÊN -->
                                <select name="maNV" class="form-select w-auto">

                                    <option value="">
                                        Tất cả Nhân Viên
                                    </option>

                                    @{
                                        var nhanVienList = ViewBag.NhanVienList as List<SelectListItem>;
                                    }

                                    @if (nhanVienList != null)
                                    {
                                        foreach (var nv in nhanVienList)
                                        {
                                            <option value="@nv.Value"
                                                    @(Request["maNV"] == nv.Value ? "selected" : "")>

                                                @nv.Text

                                            </option>
                                        }
                                    }

                                </select>

                                <!-- BUTTON -->
                                <button class="btn btn-dark px-4 rounded-3">
                                    Lọc
                                </button>
                                <button class="btn btn-dark px-4 rounded-3">
                                    Thêm điều chỉnh
                                </button>
                            </div>

                        </form>

                        <!-- TABLE -->
                        <div class="table-responsive">

                            <table class="table align-middle">

                                <thead style="background:#f8fafc;">

                                    <tr class="text-uppercase small text-secondary">

                                        <th>IDNhatKy</th>
                                        <th>MãNV (NhanVien)</th>
                                        <th>PhongBan</th>
                                        <th>LươngCBan mới</th>
                                        <th>Thay đổi</th>
                                        <th>NgàyApDung</th>
                                        <th>Ghi chú</th>

                                    </tr>

                                </thead>

                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>

                                            <!-- ID -->
                                            <td class="fw-medium">
                                                #@item.IDNhatKy
                                            </td>

                                            <!-- NHÂN VIÊN -->
                                            <td>
                                                <div class="d-flex align-items-center gap-2">

                                                    <div class="avatar"
                                                         style="width:34px;height:34px;font-size:13px;">

                                                        @(item.NhanVien != null &&!string.IsNullOrEmpty(item.NhanVien.HotenNV)? item.NhanVien.HotenNV.Substring(0,1): "N")

                                                    </div>

                                                    <div>
                                                        <div class="fw-semibold">
                                                            @(item.NhanVien?.HotenNV)
                                                        </div>

                                                        <div class="small text-muted">
                                                            @(item.NhanVien?.MaNV)
                                                        </div>
                                                    </div>
                                                </div>
                                            </td>

                                            <!-- PHÒNG BAN -->
                                            <td>
                                                @(item.NhanVien?.PhongBan?.TenPB)
                                            </td>

                                            <!-- LƯƠNG -->
                                            <td class="fw-bold">
                                                @String.Format("{0:N0}", item.LuongCBan)đ
                                            </td>

                                            <!-- THAY ĐỔI -->
                                            <td>
                                                <span class="text-primary small">
                                                    Điều chỉnh lương
                                                </span>
                                            </td>

                                            <!-- NGÀY -->
                                            <td>
                                                @(item.NgayApDung != null? Convert.ToDateTime(item.NgayApDung).ToString("yyyy-MM-dd"): "")
                                            </td>

                                            <!-- GHI CHÚ -->
                                            <td class="text-muted small">
                                                @item.GhiChu
                                            </td>

                                        </tr>
                                    }
                                </tbody>

                            </table>

                        </div>

                    </div>

                </div>

            </div>

        </div>
    </div>
</body>
</html>
